# @open-multi-agent/core@1.8.0 declares an optional peer `ai@^5`, but this app
# (and @ai-sdk/react@3) uses AI SDK v6. The app never uses core's AISdkAdapter
# — the team runs on the native OpenAI-compatible provider — so the v5 peer is
# install-time noise with no runtime effect. Relax strict peer resolution so a
# clean install (and Vercel's one-click deploy) succeeds.
legacy-peer-deps=true
